# Docker image tag used by docker-compose.yaml.
# Examples: latest, v1.0.0, 1.0.0
WEBTV_IMAGE_TAG=latest

# Host port mapped to the container HTTP port 8080.
WEBTV_PORT=8080

# HTTP listen address inside the container.
WEBTV_ADDR=:8080

# SQLite database file path inside the container.
WEBTV_DB_PATH=/data/webtv.db

# Log verbosity level: debug, info, warn, error.
WEBTV_LOG_LEVEL=info

# UI application title shown in the header.
WEBTV_APP_TITLE=WebTV

# Single connection policy for channel streams: reject or replace.
WEBTV_SINGLE_CONN_POLICY=reject

# ffmpeg binary name or absolute path inside the container.
WEBTV_FFMPEG_BIN=ffmpeg

# Stream idle timeout in seconds.
WEBTV_STREAM_IDLE_TIMEOUT_SEC=12

# Maximum stream retry attempts.
WEBTV_STREAM_RETRY_MAX=5

# Stream mode cache TTL in minutes.
WEBTV_STREAM_MODE_CACHE_TTL_MIN=360

# Enable exponential backoff for manifest fetch retries.
WEBTV_STREAM_MANIFEST_BACKOFF_ENABLED=false
